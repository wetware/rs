;; Glia prelude — standard derived forms loaded at boot.
;;
;; These macros are defined in Glia itself, proving the macro system
;; works end-to-end.  Loaded via include_str! before init.d/shell.

;; not — logical negation
(defmacro not [x]
  `(if ~x false true))

;; when — conditional with implicit do
(defmacro when [test & body]
  `(if ~test (do ~@body) nil))

;; when-not — negated when
(defmacro when-not [test & body]
  `(if ~test nil (do ~@body)))

;; and — short-circuit logical AND (uses gensym for hygiene)
(defmacro and [& args]
  (if (= (count args) 0)
    true
    (if (= (count args) 1)
      (first args)
      (let [g (gensym)]
        `(let [~g ~(first args)]
           (if ~g (and ~@(rest args)) ~g))))))

;; or — short-circuit logical OR (uses gensym for hygiene)
(defmacro or [& args]
  (if (= (count args) 0)
    nil
    (if (= (count args) 1)
      (first args)
      (let [g (gensym)]
        `(let [~g ~(first args)]
           (if ~g ~g (or ~@(rest args))))))))

;; cond — multi-branch conditional
(defmacro cond [& clauses]
  (if (= (count clauses) 0)
    nil
    (if (= (count clauses) 1)
      (first clauses)
      `(if ~(first clauses)
           ~(first (rest clauses))
           (cond ~@(rest (rest clauses)))))))

;; defn — define a named function
(defmacro defn [name params & body]
  `(def ~name (fn ~params ~@body)))

;; ---------------------------------------------------------------------------
;; Error handling — sugar over perform/with-effect-handler
;; ---------------------------------------------------------------------------

;; throw — signal a :fail effect (error)
(defmacro throw [data]
  `(perform :fail ~data))

;; try — attempt expr, return {:ok val} or {:err data}
(defmacro try [& body]
  (let [error (gensym)]
    `(with-effect-handler {:fail (fn [~error] {:err ~error})}
       {:ok (do ~@body)})))

;; or-else — default on failure
(defmacro or-else [expr default]
  (let [result (gensym)]
    `(let [~result (try ~expr)]
       (if (nil? (get ~result :err))
         (get ~result :ok)
         ~default))))

;; guard — assert or throw
(defmacro guard [test error-data]
  `(when-not ~test (throw ~error-data)))

;; try-resume — try with a recovery function that receives (err resume)
;; recover-fn is called with the error and a resume function.
;; Call (resume value) to continue the computation, or return a value to abort.
(defmacro try-resume [recover-fn & body]
  `(with-effect-handler {:fail (fn [err resume] (apply ~recover-fn (list err resume)))}
     (do ~@body)))
