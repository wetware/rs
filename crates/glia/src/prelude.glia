;; Glia prelude — standard derived forms loaded at boot.
;;
;; These macros are defined in Glia itself, proving the macro system
;; works end-to-end.  Loaded via include_str! before init.d/shell.

;; not — logical negation
(defmacro not [x]
  `(if ~x false true))

;; when — conditional with implicit do
(defmacro when [test & body]
  `(if ~test (do ~@body) nil))

;; when-not — negated when
(defmacro when-not [test & body]
  `(if ~test nil (do ~@body)))

;; and — short-circuit logical AND (uses gensym for hygiene)
(defmacro and [& args]
  (if (= (count args) 0)
    true
    (if (= (count args) 1)
      (first args)
      (let [g (gensym)]
        `(let [~g ~(first args)]
           (if ~g (and ~@(rest args)) ~g))))))

;; or — short-circuit logical OR (uses gensym for hygiene)
(defmacro or [& args]
  (if (= (count args) 0)
    nil
    (if (= (count args) 1)
      (first args)
      (let [g (gensym)]
        `(let [~g ~(first args)]
           (if ~g ~g (or ~@(rest args))))))))

;; cond — multi-branch conditional
(defmacro cond [& clauses]
  (if (= (count clauses) 0)
    nil
    (if (= (count clauses) 1)
      (first clauses)
      `(if ~(first clauses)
           ~(first (rest clauses))
           (cond ~@(rest (rest clauses)))))))

;; defn — define a named function
(defmacro defn [name params & body]
  `(def ~name (fn ~params ~@body)))

;; ---------------------------------------------------------------------------
;; Error handling — effect-based exceptions
;; ---------------------------------------------------------------------------
;;
;; Errors are an effect with target :glia.exception. `(throw err)`
;; performs the effect; `(try EXPR (catch :tag e BODY) ...)` installs
;; a handler that dispatches on the error's :glia.error/type tag.
;;
;; A non-matching catch re-throws to the next outer handler. A wildcard
;; (catch _ e BODY) matches any tag and so always handles. With no
;; handler in scope, `(throw err)` escapes eval as
;; Err(Val::Effect{effect_type: "glia.exception", data: <err>}); outer
;; callers (kernel REPL, MCP cell, shell) unwrap via
;; `glia::error::unwrap_thrown`.
;;
;; Schema: errors are Val::Maps keyed by :glia.error/type and
;; :glia.error/message. User code constructs them via `(ex-info "msg"
;; {:type :foo})`, which stamps both the namespaced canonical fields
;; and the user's bare :type/:message for back-compat.

;; throw — signal a :glia.exception effect (uncaught error)
(defmacro throw [data]
  `(perform :glia.exception ~data))

;; try-catches — internal helper macro that emits the dispatch cond.
;;
;; Receives the gensym'd err/tag bindings from `try` and walks the
;; remaining catch clauses recursively. Each level either:
;;   - emits the wildcard branch (and ignores any later clauses), OR
;;   - emits an `if` matching the tag and recursing on remaining catches, OR
;;   - emits a re-throw if there are no catches left.
(defmacro try-catches [err-sym tag-sym & catches]
  (if (= (count catches) 0)
    `(perform :glia.exception ~err-sym)
    (let [c (first catches)
          rest-catches (rest catches)
          tag (first (rest c))
          sym (first (rest (rest c)))
          body (rest (rest (rest c)))]
      (if (= tag (quote _))
        `(let [~sym ~err-sym] (do ~@body))
        `(if (= ~tag-sym ~tag)
             (let [~sym ~err-sym] (do ~@body))
             (try-catches ~err-sym ~tag-sym ~@rest-catches))))))

;; try — evaluate EXPR; on a :glia.exception, dispatch by :glia.error/type
;; through the catch clauses. Without catches, any throw escapes.
;; Returns the body's value on success, or the matching catch body's
;; value on failure.
;;
;; (try (compute)
;;   (catch :glia.error/unbound-symbol e (recover e))
;;   (catch :network                 e (retry e))
;;   (catch _                        e (rethrow-as-internal e)))
(defmacro try [expr & catches]
  (let [err-sym (gensym)
        tag-sym (gensym)]
    `(with-effect-handler :glia.exception
       (fn [~err-sym]
         ;; A throw can carry any Val (int, string, vector, …); only
         ;; structured maps with :glia.error/type are tag-dispatchable.
         ;; Anything else falls through to the wildcard.
         (let [~tag-sym (if (map? ~err-sym)
                            (get ~err-sym :glia.error/type)
                            nil)]
           (try-catches ~err-sym ~tag-sym ~@catches)))
       ~expr)))

;; or-else — return EXPR's value, or DEFAULT if EXPR throws.
(defmacro or-else [expr default]
  `(try ~expr (catch _ _err ~default)))

;; guard — assert or throw with a structured error.
;;
;; (guard (> n 0) (ex-info "must be positive" {:type :invalid}))
(defmacro guard [test error-data]
  `(when-not ~test (throw ~error-data)))

;; try-resume — install a resumable :glia.exception handler.
;;
;; recover-fn receives (err resume); call (resume value) to continue
;; the throwing computation with that value, or return a value from
;; recover-fn to abort. Use this for retry/recovery patterns where the
;; thrower can be resumed at the call site.
(defmacro try-resume [recover-fn & body]
  `(with-effect-handler :glia.exception
     (fn [err resume] (apply ~recover-fn (list err resume)))
     (do ~@body)))

;; ---------------------------------------------------------------------------
;; Capability scoping
;; ---------------------------------------------------------------------------

;; with — capability grant bindings (sugar over let)
;;
;; Signals intent: "these are capability grants to the body."
;; Semantically identical to let, but reads as a policy declaration.
;; Composes with with-effect-handler for eval-time attenuation.
(defmacro with [bindings & body]
  `(let ~bindings ~@body))
