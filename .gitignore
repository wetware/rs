# Web Assembly files (build artifacts — rebuild with `make`)
*.wasm


# Generated by Cargo
# will have compiled files and executables
debug/
target/

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Example-specific build artifacts
examples/*/target/
examples/*/*.cid
# Temporary local work area
tmp/

# Identity files — generated by `ww keygen`, never committed
**/etc/identity

wit/cell.wit
.DS_Store
.gstack/
