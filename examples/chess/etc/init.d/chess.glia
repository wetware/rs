; Chess init.d script — evaluated by the kernel at boot.
;
; Each form is a capability invocation using the kernel's evaluator.
; Inner expressions are evaluated first (recursive eval).

; Run the chess demo in service mode — blocks until exit.
; The service process handles DHT discovery, Terminal auth, remote
; executor capability shipping, and typed ChessEngine RPC.
(executor run (ipfs cat "bin/chess-demo.wasm")
  :env {"WW_NS" "ww.chess.v1"})
